FLASK_ENV=development
# Kaggle credentials (only needed to run seed_data/seed_meals_kaggle.py)
# Get yours at kaggle.com/settings -> API -> Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
SECRET_KEY=change-me-in-prod
DATABASE_URL=sqlite:///nutritrack.db
AUTH_ENABLED=true
DEFAULT_PROTEIN_TARGET=150
DEFAULT_FAT_TARGET=65
DEFAULT_CARBS_TARGET=250
DEFAULT_CALORIES_TARGET=2200
